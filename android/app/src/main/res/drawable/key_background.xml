<?xml version="1.0" encoding="utf-8"?>
<!-- Rounded key with insets that create the gaps between keys. -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <inset android:insetLeft="1.5dp" android:insetRight="1.5dp"
            android:insetTop="2dp" android:insetBottom="2dp">
            <shape android:shape="rectangle">
                <solid android:color="#5A5A5E" />
                <corners android:radius="7dp" />
            </shape>
        </inset>
    </item>
    <item>
        <inset android:insetLeft="1.5dp" android:insetRight="1.5dp"
            android:insetTop="2dp" android:insetBottom="2dp">
            <shape android:shape="rectangle">
                <solid android:color="#3A3A3C" />
                <corners android:radius="7dp" />
            </shape>
        </inset>
    </item>
</selector>
